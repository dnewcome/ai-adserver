ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Local native Postgres via Unix socket (trust auth, no password):
DATABASE_URL=postgresql+asyncpg://adserver@/adserver?host=/var/run/postgresql&port=5433
# Or Docker Compose (maps container 5432 to host 5433 to avoid conflicts):
# DATABASE_URL=postgresql+asyncpg://adserver:adserver@localhost:5433/adserver
REDIS_URL=redis://localhost:6379/0

SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Optional: image generation
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Instagram Basic Display API
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
